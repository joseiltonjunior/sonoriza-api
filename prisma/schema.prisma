// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Music {
  id          String    @id @default(uuid())
  title       String
  slug        String    @unique
  album       String?
  coverPath   String?   @map("cover_path")
  audioPath   String    @map("audio_path")
  color       String?
  like        Int       @default(0)
  view        Int       @default(0)
  durationSec Int?      @map("duration_seconds")
  releaseDate DateTime? @map("release_date")

  genreId String? @map("genre_id")
  genre   Genre?  @relation(fields: [genreId], references: [id])

  artists MusicArtist[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([genreId])
  @@map("musics")
}

model Artist {
  id       String @id @default(uuid())
  name     String
  photoURL String @map("photo_url")
  like     Int    @default(0)

  musics        MusicArtist[]
  musicalGenres ArtistGenre[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@map("artists")
}

model Genre {
  id   String @id @default(uuid())
  name String @unique

  musics  Music[]
  artists ArtistGenre[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@map("genres")
}

model MusicArtist {
  musicId  String @map("music_id")
  artistId String @map("artist_id")

  music  Music  @relation(fields: [musicId], references: [id], onDelete: Cascade)
  artist Artist @relation(fields: [artistId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@id([musicId, artistId])
  @@index([artistId])
  @@map("music_artists")
}

model ArtistGenre {
  artistId String @map("artist_id")
  genreId  String @map("genre_id")

  artist Artist @relation(fields: [artistId], references: [id], onDelete: Cascade)
  genre  Genre  @relation(fields: [genreId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@id([artistId, genreId])
  @@index([genreId])
  @@map("artist_genres")
}
