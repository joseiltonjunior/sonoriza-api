// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

model User {
  id       String   @id @default(uuid())
  name     String
  email    String   @unique
  password String
  role     Role     @default(USER)
  isActive Boolean  @default(true) @map("is_active")
  photoUrl String?  @map("photo_url")

  musicLikes  MusicLike[]
  artistLikes ArtistLike[]
  musicViews  MusicView[]
  sessions    Session[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([role])
  @@index([deletedAt])
  @@map("users")
}

model Music {
  id          String    @id @default(uuid())
  title       String
  slug        String    @unique
  album       String?
  coverPath   String?   @map("cover_path")
  audioPath   String    @map("audio_path")
  color       String?
  likesCount  Int       @default(0) @map("like_count")
  viewsCount  Int       @default(0) @map("view_count")
  durationSec Int?      @map("duration_seconds")
  releaseDate DateTime? @map("release_date")

  genreId String? @map("genre_id")
  genre   Genre?  @relation(fields: [genreId], references: [id])

  artists MusicArtist[]
  likes   MusicLike[]
  views   MusicView[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([genreId])
  @@index([createdAt])
  @@index([releaseDate])
  @@index([deletedAt])
  @@map("musics")
}

model Artist {
  id         String @id @default(uuid())
  name       String
  photoURL   String @map("photo_url")
  likesCount Int    @default(0) @map("like_count")

  musics        MusicArtist[]
  musicalGenres ArtistGenre[]
  likes         ArtistLike[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([deletedAt])
  @@map("artists")
}

model Genre {
  id   String @id @default(uuid())
  name String @unique

  musics  Music[]
  artists ArtistGenre[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@map("genres")
}

model MusicArtist {
  musicId  String @map("music_id")
  artistId String @map("artist_id")

  music  Music  @relation(fields: [musicId], references: [id], onDelete: Cascade)
  artist Artist @relation(fields: [artistId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@id([musicId, artistId])
  @@index([artistId])
  @@map("music_artists")
}

model ArtistGenre {
  artistId String @map("artist_id")
  genreId  String @map("genre_id")

  artist Artist @relation(fields: [artistId], references: [id], onDelete: Cascade)
  genre  Genre  @relation(fields: [genreId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@id([artistId, genreId])
  @@index([genreId])
  @@map("artist_genres")
}

model MusicLike {
  userId  String @map("user_id")
  musicId String @map("music_id")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  music Music @relation(fields: [musicId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@id([userId, musicId])
  @@index([musicId])
  @@index([createdAt])
  @@map("music_likes")
}

model ArtistLike {
  userId   String @map("user_id")
  artistId String @map("artist_id")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  artist Artist @relation(fields: [artistId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@id([userId, artistId])
  @@index([artistId])
  @@index([createdAt])
  @@map("artist_likes")
}

model Session {
  id               String    @id @default(uuid())
  userId           String    @map("user_id")
  refreshTokenJti  String    @unique @map("refresh_token_jti")
  refreshTokenHash String    @map("refresh_token_hash")
  expiresAt        DateTime  @map("expires_at")
  revokedAt        DateTime? @map("revoked_at")
  lastUsedAt       DateTime? @map("last_used_at")
  replacedById     String?   @map("replaced_by_id")

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  replacedBy Session?  @relation("SessionReplacement", fields: [replacedById], references: [id])
  replaced   Session[] @relation("SessionReplacement")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
  @@map("sessions")
}

model MusicView {
  id            String  @id @default(uuid())
  musicId       String  @map("music_id")
  userId        String? @map("user_id")
  ipHash        String? @map("ip_hash")
  userAgentHash String? @map("user_agent_hash")

  music Music @relation(fields: [musicId], references: [id], onDelete: Cascade)
  user  User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([musicId])
  @@index([userId])
  @@index([createdAt])
  @@index([musicId, createdAt])
  @@map("music_views")
}
